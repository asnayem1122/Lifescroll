# ──────────────────────────────────────────────────────────
# Lifescroll — Server Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file.
# ──────────────────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/lifescroll
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/lifescroll
MONGODB_URI=mongodb://localhost:27017/lifescroll

# A long, random secret used to sign JWT tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Port the Express server listens on
PORT=5000

# URL of the running Vite dev server (used for CORS)
CLIENT_URL=http://localhost:5173

# 'development' | 'production'
NODE_ENV=development
